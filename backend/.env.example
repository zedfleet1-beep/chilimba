# Backend environment. Copy to backend/.env and fill in real values.
# DO NOT commit backend/.env.

NODE_ENV=development
PORT=4500

# Database (matches docker-compose.yml 'postgres' service)
DATABASE_URL=postgresql://chilimba:chilimba_dev@localhost:5433/chilimba?schema=public

# Redis (matches docker-compose.yml 'redis' service)
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-please
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars-please
JWT_GROUP_TOKEN_SECRET=dev-group-token-secret-change-me-min-32-chars-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Evolution API — run from ../evolution-api/ via docker compose
EVOLUTION_URL=http://localhost:8080
EVOLUTION_INSTANCE=chilimba
EVOLUTION_API_KEY=replace-with-your-evolution-api-key
EVOLUTION_ENABLED=true

# S3 / MinIO (matches docker-compose.yml 'minio' service)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=chilimba-pops
S3_ACCESS_KEY=chilimba_minio
S3_SECRET_KEY=chilimba_minio_secret
S3_FORCE_PATH_STYLE=true

# Web base URL — used to build group-creation links in WhatsApp messages
WEB_BASE_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug

# Cloudinary (used for payment-proof uploads).
# Set CLOUDINARY_CLOUD_NAME / CLOUDINARY_API_KEY / CLOUDINARY_API_SECRET in
# your environment. The free tier is sufficient for early dev.
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
# CLOUDINARY_UPLOAD_TIMEOUT_MS=120000
