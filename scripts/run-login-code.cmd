@echo off
npx playwright-cli -s=chilimba run-code "async page => { const out = { responses: [] }; page.on('response', async res => { if (res.url().includes('auth/login')) { let body = ''; try { body = await res.text(); } catch (e) {} out.responses.push({ status: res.status(), url: res.url(), body: body.slice(0, 300) }); } }); await page.goto('https://chilimba.zedfleet.com/login?next=/dashboard'); await page.locator('input[type=tel]').fill('963285865'); await page.locator('input[type=password]').fill('Prince'); await page.getByRole('button', { name: /sign in/i }).waitFor({ state: 'visible' }); out.signInDisabled = await page.getByRole('button', { name: /sign in/i }).isDisabled(); if (!out.signInDisabled) { await page.getByRole('button', { name: /sign in/i }).click(); await page.waitForTimeout(4000); } out.finalUrl = page.url(); out.title = await page.title(); out.errors = await page.locator('.text-red-600').allTextContents().catch(() => []); out.bodySnippet = (await page.locator('body').innerText()).slice(0, 900); return out; }"