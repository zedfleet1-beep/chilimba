# =========================================================================
# Chilimba — shared environment shape
# Copy this file to .env (root) for shared values, and to
# backend/.env and frontend/.env as appropriate. Never commit .env.
# =========================================================================

# --- Backend ---
NODE_ENV=development
PORT=4000

# Postgres (matches docker-compose.yml service 'postgres')
DATABASE_URL=postgresql://chilimba:chilimba_dev@localhost:5432/chilimba?schema=public

# Redis (matches docker-compose.yml service 'redis')
REDIS_URL=redis://localhost:6379

# JWT — generate strong random values for production
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Evolution API (run from ../evolution-api via docker compose)
EVOLUTION_URL=http://localhost:8080
EVOLUTION_INSTANCE=chilimba
EVOLUTION_API_KEY=replace-with-evolution-api-key
# Phone number shown to group owners when linking WhatsApp (E.164, e.g. +260...)
CHILIMBA_WHATSAPP_PHONE=

# S3 / MinIO (matches docker-compose.yml service 'minio')
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=chilimba-pops
S3_ACCESS_KEY=chilimba_minio
S3_SECRET_KEY=chilimba_minio_secret
S3_FORCE_PATH_STYLE=true

# Web base URL — used to build group-creation links sent via WhatsApp
WEB_BASE_URL=http://localhost:5173

# --- Frontend ---
VITE_API_BASE=/api/v1
